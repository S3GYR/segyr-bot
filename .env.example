# Required secrets (production)
SEGYR_DB_PASSWORD=CHANGE_ME_DB_PASSWORD_MIN_16_CHARS
SEGYR_JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
SEGYR_API_AUTH_TOKEN=CHANGE_ME_API_TOKEN_MIN_16_CHARS

# API
SEGYR_API_TOKEN_HEADER=X-API-Token
SEGYR_API_TRUSTED_HOSTS=localhost,127.0.0.1,api,segyr-api

# Global rate limit (Redis-backed)
SEGYR_GLOBAL_RATE_LIMIT_ENABLED=true
SEGYR_GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60
SEGYR_GLOBAL_RATE_LIMIT_MAX_REQUESTS=120
SEGYR_GLOBAL_RATE_LIMIT_FAIL_CLOSED=false

# HTTP security headers
SEGYR_HTTP_HSTS_MAX_AGE=63072000
SEGYR_HTTP_CSP=default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none';
SEGYR_HTTP_REFERRER_POLICY=strict-origin-when-cross-origin

# Database
SEGYR_DB_HOST=postgres
SEGYR_DB_PORT=5432
SEGYR_DB_NAME=segyrbot
SEGYR_DB_USER=segyr

# Redis
SEGYR_REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# JWT
SEGYR_JWT_ALGO=HS256
SEGYR_JWT_EXP_MIN=60

# Optional notifications
SEGYR_SMTP_HOST=
SEGYR_SMTP_PORT=
SEGYR_SMTP_USER=
SEGYR_SMTP_PASSWORD=
SEGYR_SMTP_FROM=
# Telegram (API notifications + gateway channel fallback)
SEGYR_TELEGRAM_BOT_TOKEN=
SEGYR_TELEGRAM_CHAT_ID=

# WhatsApp / Evolution API
SEGYR_EVOLUTION_API_BASE=
SEGYR_EVOLUTION_API_KEY=
SEGYR_EVOLUTION_INSTANCE=
SEGYR_EVOLUTION_WEBHOOK_SECRET=

# Runtime paths
SEGYR_WORKSPACE=workspace
SEGYR_LOGS_PATH=logs

# Runtime settings
SEGYR_DEBUG=false
SEGYR_LOG_LEVEL=INFO

# Auto-repair safety
SEGYR_AUTO_REPAIR_ENABLED=true
# run | dry-run | approval_required
SEGYR_AUTO_REPAIR_MODE=run
AUTO_REPAIR_ENABLED=true
AUTO_REPAIR_MODE=run

# Alert loop service
SEGYR_ALERT_POLL_INTERVAL=30
SEGYR_ALERT_COOLDOWN_SECONDS=300
SEGYR_ALERT_AUTO_REPAIR_MIN_SCORE=70

# LLM (Ollama)
SEGYR_LLM_PROVIDER=litellm
SEGYR_LLM_API_BASE=http://ollama:11434
SEGYR_LLM_MODEL=ollama/qwen3.5:9b
SEGYR_LLM_FALLBACK_MODEL=ollama/qwen3.5:4b
SEGYR_LLM_MODE=quality
SEGYR_LLM_TIMEOUT=120
SEGYR_LLM_RETRY_ATTEMPTS=2
SEGYR_LLM_MAX_TOKENS=700
SEGYR_LLM_TEMPERATURE=0.15

# Multi-provider example (OpenAI)
# SEGYR_LLM_PROVIDER=openai
# SEGYR_LLM_MODEL=gpt-4o-mini
# SEGYR_LLM_API_KEY=sk-...
# SEGYR_LLM_API_BASE=https://api.openai.com/v1
