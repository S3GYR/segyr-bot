# API
SEGYR_API_AUTH_TOKEN=segyr-token
SEGYR_API_TOKEN_HEADER=X-API-Token

# Compose/production variables (referenced by docker-compose.yml)
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
REDIS_URL=redis://redis:6379/0
JWT_SECRET=CHANGE_ME_JWT_SECRET
TELEGRAM_TOKEN=

# Internal app variables (can also be used outside Docker)
SEGYR_JWT_SECRET=CHANGE_ME_JWT_SECRET
SEGYR_JWT_ALGO=HS256
SEGYR_JWT_EXP_MIN=60

# Database
SEGYR_DB_HOST=postgres
SEGYR_DB_PORT=5432
SEGYR_DB_NAME=segyrbot
SEGYR_DB_USER=segyr
SEGYR_DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Redis
SEGYR_REDIS_HOST=redis
SEGYR_REDIS_PORT=6379
SEGYR_REDIS_DB=0

# SMTP (optionnel)
SEGYR_SMTP_HOST=
SEGYR_SMTP_PORT=
SEGYR_SMTP_USER=
SEGYR_SMTP_PASSWORD=
SEGYR_SMTP_FROM=

# Telegram (optionnel)
SEGYR_TELEGRAM_BOT_TOKEN=
SEGYR_TELEGRAM_CHAT_ID=

# Logs / workspace
SEGYR_WORKSPACE=workspace
SEGYR_LOGS_PATH=logs

# Debug
SEGYR_DEBUG=false
SEGYR_LOG_LEVEL=INFO
